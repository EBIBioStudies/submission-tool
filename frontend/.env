## This configuration is only used locally, once deployed, they get overriden by GitLab CI/CD variables
VITE_BASE_URL=/biostudies/submissions/

# Feature flags
VITE_ENABLE_SUBMISSION=true

# Announcement configuration
VITE_ANNOUNCEMENT_ENABLED=false
VITE_ANNOUNCEMENT_HEADLINE=Headline example
VITE_ANNOUNCEMENT_MESSAGE=Headline message which <b>can contain</b> <a>html</a>
# Possible values: info, warning, alert, success
VITE_ANNOUNCEMENT_PRIORITY=warning
