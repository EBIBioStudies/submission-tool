VITE_BASE_URL=/biostudies/submissions/

# Feature flags
VITE_ENABLE_SUBMISSION=true

# Announcement configuration
VITE_ANNOUNCEMENT_ENABLED=true
VITE_ANNOUNCEMENT_HEADLINE=Scheduled Maintenance Notice
VITE_ANNOUNCEMENT_MESSAGE=Please be advised that the our submission services will be unavailable due to scheduled maintenance on 7th May 2026 and from 11th May 2026 until 14th May 2026. The existing submissions will remain accessible, but new studies cannot be submitted or released during this period.
# Possible values: info, warning, alert, success
VITE_ANNOUNCEMENT_PRIORITY=warning
